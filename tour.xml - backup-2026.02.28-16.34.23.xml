<krpano version="1.23" title="Virtual Tour">

	<include url="skin/vtourskin.xml" />
	<events onclick="trace('ath=',view.hlookat,' atv=',view.vlookat);" />

	<layer name="logo" url="skin/logo.svg" align="lefttop" x="20" y="10" keep="true" />

	<!-- customize skin settings: maps, gyro, webvr, thumbnails, tooltips, layout, design, ... -->
	<skin_settings maps="false"
	               maps_type="openstreetmaps"
	               maps_bing_api_key=""
	               maps_google_api_key=""
	               maps_zoombuttons="false"
	               maps_loadonfirstuse="true"
	               gyro="true"
	               gyro_keeplookingdirection="false"
	               webvr="false"
	               webvr_keeplookingdirection="true"
	               webvr_prev_next_hotspots="true"
	               autotour="false"
	               littleplanetintro="false"
	               followmousecontrol="false"
	               title="true"
	               thumbs="true"
	               thumbs_width="120" thumbs_height="80" thumbs_padding="10" thumbs_crop="0|40|240|160"
	               thumbs_opened="false"
	               thumbs_text="false"
	               thumbs_dragging="true"
	               thumbs_onhoverscrolling="false"
	               thumbs_scrollbuttons="false"
	               thumbs_scrollindicator="false"
	               thumbs_loop="false"
	               tooltips_buttons="false"
	               tooltips_thumbs="false"
	               tooltips_hotspots="true"
	               tooltips_mapspots="false"
	               deeplinking="false"
	               loadscene_flags="MERGE"
	               loadscene_blend="OPENBLEND(0.5, 0.0, 0.75, 0.05, linear)"
	               loadscene_blend_prev="SLIDEBLEND(0.5, 180, 0.75, linear)"
	               loadscene_blend_next="SLIDEBLEND(0.5,   0, 0.75, linear)"
	               loadingtext=""
	               layout_width="100%"
	               layout_maxwidth="550"
	               controlbar_width="-24"
	               controlbar_height="40"
	               controlbar_offset="20"
	               controlbar_offset_closed="-40"
	               controlbar_overlap.no-fractionalscaling="10"
	               controlbar_overlap.fractionalscaling="0"
	               design_skin_images="vtourskin.png"
	               design_bgcolor="0x003d38"
	               design_bgalpha="0.8"
	               design_bgborder="0"
	               design_bgroundedge="1"
	               design_bgshadow="0 4 10 0x000000 0.3"
	               design_thumbborder_bgborder="3 0xFFFFFF 1.0"
	               design_thumbborder_padding="2"
	               design_thumbborder_bgroundedge="0"
	               design_text_css="color:#FFFFFF; font-family:Arial;"
	               design_text_shadow="1"
	               />

	<!--
	    For an alternative skin design either change the <skin_settings> values 
	    from above or optionally include one of the predefined designs from below.
	-->
	<!-- <include url="skin/vtourskin_design_flat_light.xml"  /> -->
	<!-- <include url="skin/vtourskin_design_glass.xml"       /> -->
	<!-- <include url="skin/vtourskin_design_ultra_light.xml" /> -->
	<!-- <include url="skin/vtourskin_design_117.xml"         /> -->
	<!-- <include url="skin/vtourskin_design_117round.xml"    /> -->
	<!-- <include url="skin/vtourskin_design_black.xml"       /> -->

	<action name="updateradar">
		set(layer[floorplan_hotspotactive].parent, %1);
		set(plugin[radar].parent, %1);
		tween(plugin[radar].heading, %2);
	</action>

	<events name="floorplan_scene_control"
		keep="true"
		onnewscene="
			if(xml.scene == 'scene_mbh_360_nthyi_thtgkt_01',
				updateradar(floorplan_hotspot1);
			);
			if(xml.scene == 'scene_mbh_360_nthyi_thtgkt_02',
				updateradar(floorplan_hotspot2);
			);
		"
	/>

	<scene  onstart="updateradar(floorplan_hotspot1, 0)" name="scene_mbh_360_nthyi_thtgkt_01" title="MBH_360 NỘI THẤT_01" thumburl="panos/MBH_360_NthyI_THtgkT_01.tiles/thumb.jpg">

		<control bouncinglimits="calc:image.cube ? true : false" />

		<view hlookat="0.0" vlookat="0.0" fovtype="MFOV" fov="120" maxpixelzoom="2.0" fovmin="70" fovmax="140" limitview="auto" />

		<preview url="panos/MBH_360_NthyI_THtgkT_01.tiles/preview.jpg" />

		<image>
			<cube url="panos/MBH_360_NthyI_THtgkT_01.tiles/%s/l%l/%v/l%l_%s_%v_%h.jpg" multires="512,768,1600" />
		</image>

		<!-- Tooltip 1 -->
		<hotspot name="tooltip1"
				ath="10.0"
				atv="5.0"
				type="text"
				html="&lt;div style='--line-height: 100px;' class='tooltip-area'&gt;Tooltip số 1&lt;/div&gt;"
				padding="10"
				cursor="default"
         		capture="false"
				background="false"
				visible="true" />

		<!-- Tooltip 2 -->
		<hotspot name="tooltip2"
				ath="-20.0"
				atv="8.0"
				type="text"
				html="&lt;div style='--line-height: 100px;'class='tooltip-area'&gt;Tooltip số 2&lt;/div&gt;"
				padding="10"
				cursor="default"
         		capture="false"
				background="false"
				visible="true" />
				
		<hotspot name="spot1942678777" style="IconHomeview01" ath="-1.855" atv="20.0" linkedscene="scene_mbh_360_nthyi_thtgkt_02" onclick="if(linkedscene, loadscene(get(linkedscene), null, MERGE, BLEND(1)));" linkedscene_hoffset="0.0" use3dtransition="true" />
		<hotspot name="spot1942795415" style="IconHomeview01" ath="-166.639" atv="9.119" depth="1000.0" linkedscene="scene_mbh_360_nthyi_thtgkt_02" onclick="if(linkedscene, loadscene(get(linkedscene), null, MERGE, BLEND(1)));" linkedscene_hoffset="0.0" use3dtransition="true" />

		<layer name="floorplan_container" type="container" bgColor="0xFFFFFF" bgAlpha="0.8" width="300" height="400" align="right"  keep="true" >
			<layer name="floorplan_image" type="image" url="floorplans/floorplan1.png" width="300" height="400" align="center">
				<layer name="floorplan_hotspot1" type="container" bgColor="0x003d38" bgborder="2 0xFFFFFF 1" bgroundedge="10" bgAlpha="1" width="10" height="10" x="150" y="200" onclick="loadscene(scene_mbh_360_nthyi_thtgkt_01, null, MERGE, BLEND(1));" capture="true" cursor="pointer" zorder="10" />
				<layer name="floorplan_hotspot2" type="container" bgColor="0x003d38" bgborder="2 0xFFFFFF 1" bgroundedge="10" bgAlpha="1" width="10" height="10" x="150" y="100" onclick="loadscene(scene_mbh_360_nthyi_thtgkt_02, null, MERGE, BLEND(1));" capture="true" cursor="pointer" zorder="10" />
			</layer>
			
			<plugin name="radar"
			url="%VIEWER%/plugins/radar.js"
			parent="floorplan_container"
			align="center"
			edge="center"
			x="0" y="0"
			scale="0.3"
			heading="0.0"
			headingoffset="0"
			fillcolor="0x003d38"
			fillalpha="0.5"
			linewidth="0.0"
			linecolor="0xFFFFFF"
			linealpha="0.3"
			invert="false"
			customhlookat=""
			customhfov=""
			oncustomchange=""
			/>

			<layer name="floorplan_hotspotactive" type="container" bgColor="0x000000" bgborder="2 0xFF0000 1" bgroundedge="10" bgAlpha="1" width="10" align="center" edge="" height="10" x="0" y="0" />
		</layer>
	</scene>

	<action name="startupzoom">
		set(view.fov, 1000);
    	tween(view.fov, 100, 3, easeOutCubic);
	</action>

<!-- update floorplan -->
	<events name="floorplan_control"
        keep="true"
        onnewscene="
          if(xml.scene == 'scene_mbh_360_nthyi_thtgkt_01' OR
             xml.scene == 'scene_mbh_360_nthyi_thtgkt_02',
             set(layer[floorplan_container].visible, true);
             ,
             set(layer[floorplan_container].visible, false);
          );
        " />

	<scene onstart="updateradar(floorplan_hotspot2, 0)" name="scene_mbh_360_nthyi_thtgkt_02" title="MBH_360 NỘI THẤT_02" thumburl="panos/MBH_360_NthyI_THtgkT_02.tiles/thumb.jpg" lat="" lng="" alt="" heading="">
		
		<control bouncinglimits="calc:image.cube ? true : false" />

		<view hlookat="0.0" vlookat="0.0" fovtype="MFOV" fov="120" maxpixelzoom="2.0" fovmin="70" fovmax="140" limitview="auto" />

		<preview url="panos/MBH_360_NthyI_THtgkT_02.tiles/preview.jpg" />

		<image>
			<cube url="panos/MBH_360_NthyI_THtgkT_02.tiles/%s/l%l/%v/l%l_%s_%v_%h.jpg" multires="512,768,1600" />
		</image>

	</scene>

	<scene name="scene_mbh_360_nthyi_thtgkt_03" title="MBH_360 NỘI THẤT_03" onstart="" thumburl="panos/MBH_360_NthyI_THtgkT_03.tiles/thumb.jpg" lat="" lng="" alt="" heading="">
		
		<control bouncinglimits="calc:image.cube ? true : false" />

		<view hlookat="0.0" vlookat="0.0" fovtype="MFOV" fov="120" maxpixelzoom="2.0" fovmin="70" fovmax="140" limitview="auto" />

		<preview url="panos/MBH_360_NthyI_THtgkT_03.tiles/preview.jpg" />

		<image>
			<cube url="panos/MBH_360_NthyI_THtgkT_03.tiles/%s/l%l/%v/l%l_%s_%v_%h.jpg" multires="512,768,1600" />
		</image>

		<hotspot name="video"
         url="%VIEWER%/plugins/videoplayer.js"
         videourl="https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/BigBuckBunny.mp4"
         posterurl=""
         ath="0.0" atv="0.0"
         distorted="true"
         scale="1.0" 
         rx="-120" 
         ry="10" 
         rz="0.0" 
         pausedonstart="false"
         loop="false"
         volume="1.0"
         onvideoready=""
         onvideoplay=""
         onvideopaused=""
         onvideocomplete=""
         onerror=""
         />

	</scene>

	<scene name="scene_mbh_360_nthyi_thtgkt_04" title="MBH_360 NỘI THẤT_04" onstart="" thumburl="panos/MBH_360_NthyI_THtgkT_04.tiles/thumb.jpg" lat="" lng="" alt="" heading="">
		
		<control bouncinglimits="calc:image.cube ? true : false" />

		<view hlookat="0.0" vlookat="0.0" fovtype="MFOV" fov="120" maxpixelzoom="2.0" fovmin="70" fovmax="140" limitview="auto" />

		<preview url="panos/MBH_360_NthyI_THtgkT_04.tiles/preview.jpg" />

		<image>
			<cube url="panos/MBH_360_NthyI_THtgkT_04.tiles/%s/l%l/%v/l%l_%s_%v_%h.jpg" multires="512,768,1600" />
		</image>

	</scene>

	<scene name="scene_mbh_360_nthyi_thtgkt_05" title="MBH_360 NỘI THẤT_05" onstart="" thumburl="panos/MBH_360_NthyI_THtgkT_05.tiles/thumb.jpg" lat="" lng="" alt="" heading="">
		
		<control bouncinglimits="calc:image.cube ? true : false" />

		<view hlookat="0.0" vlookat="0.0" fovtype="MFOV" fov="120" maxpixelzoom="2.0" fovmin="70" fovmax="140" limitview="auto" />

		<preview url="panos/MBH_360_NthyI_THtgkT_05.tiles/preview.jpg" />

		<image>
			<cube url="panos/MBH_360_NthyI_THtgkT_05.tiles/%s/l%l/%v/l%l_%s_%v_%h.jpg" multires="512,768,1600" />
		</image>

	</scene>


</krpano>
